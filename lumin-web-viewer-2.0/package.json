{
  "name": "lumin-web-viewer",
  "author": "Lumin",
  "version": "6.5.6",
  "description": "WebViewer UI built in React",
  "homepage": "./",
  "main": "electron/main.js",
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "prepare-commit-msg": "node scripts/prepare-commit-msg.js",
    "download-webviewer": "pnpx @pdftron/webviewer-downloader --core-only --path ./lib",
    "dev:legacy": "NODE_ENV=development babel-node ./dev-server.js",
    "electron": "concurrently \"pnpm start\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:dev": "NODE_ENV=development concurrently \"pnpm start\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:dev:rspack": "NODE_ENV=development concurrently \"pnpm run start:rspack:no-open\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:dist": "NODE_ENV=production pnpm run generate-electron-config && electron-builder --config electron-builder.config.js",
    "electron:dist:test": "NODE_ENV=production pnpm run generate-electron-config && electron-builder build --dir --mac --arm64 --publish never --config electron-builder.config.js",
    "electron:dist:mac": "NODE_ENV=production pnpm run generate-electron-config && electron-builder build --mac --config electron-builder.config.js",
    "electron:dist:win": "NODE_ENV=production pnpm run generate-electron-config && electron-builder build --win --config electron-builder.config.js",
    "electron:dist:linux": "NODE_ENV=production pnpm run generate-electron-config && electron-builder build --linux --config electron-builder.config.js",
    "dev": "NODE_ENV=development rspack serve --config ./rspack.config.dev.js",
    "test-jest": "jest -w 1 --config ./jest.config.json",
    "test-jest:silent": "jest --config ./jest.config.json --reporters=jest-silent-reporter -u",
    "test-jest:coverage": "jest -w 1 --config ./jest.config.json --coverage -u",
    "test-jest:badges": "jest -w 4 --config ./jest.config.json --coverage -u && jest-coverage-badges input \"src/coverage/coverage-summary.json\" output \"badges\" --forceExit",
    "test-jest:check-test-coverage": "node scripts/check-test-coverage.js",
    "cypress:open": "cypress open --project ./test/cypress",
    "lint": "eslint ./src/**/*.js",
    "lint:electron": "eslint ./electron/**/*.js --config ./electron/.eslintrc.electron.js",
    "lint:all": "pnpm run lint && pnpm run lint:electron",
    "eslint-build": "git diff --name-only origin/$npm_config_branch | grep -E '.(js|jsx|ts|tsx)$' | xargs -r eslint --quiet --no-error-on-unmatched-pattern",
    "stylelint-build": "git diff --name-only origin/$npm_config_branch | grep -E '.(css|scss|styled.js|styled.ts)$' | awk -v def=\"*.none\" '{print} END { if(NR==0) {print def} }' | xargs stylelint --quiet --allow-empty-input",
    "lint:fix": "eslint --fix ./src/**/*.js",
    "lint:fix:electron": "eslint --fix ./electron/**/*.js --config ./electron/.eslintrc.electron.js",
    "lint:fix:all": "pnpm run lint:fix && pnpm run lint:fix:electron",
    "clean": "rimraf build && rimraf dist",
    "bundle": "webpack --progress --config ./webpack.config.prod.js",
    "bundle:rspack": "rspack build --config ./rspack.config.prod.js",
    "build": "pnpm run clean && pnpm run prebuild && NODE_ENV=production pnpm run bundle",
    "build:rspack": "pnpm run clean && pnpm run prebuild && NODE_ENV=production pnpm run bundle:rspack",
    "build:analyze": "pnpm run clean && pnpm run prebuild && NODE_ENV=production ANALYZE_BUNDLE=true pnpm run bundle",
    "build:measure": "node scripts/measure-build-performance.js measure",
    "build:with-timing": "pnpm run clean && pnpm run prebuild && echo 'Starting build...' && time NODE_ENV=production pnpm run bundle",
    "generate-build-version": "node ./scripts/generate-build-version",
    "generate-electron-config": "node ./scripts/generate-electron-config.js",
    "prebuild": "pnpm run generate-build-version",
    "prepare": "husky install",
    "preinstall": "npm config set engine-strict true"
  },
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx}": [
      "npx eslint --fix --quiet --cache"
    ],
    "**/*.json": [
      "npx eslint --fix --quiet"
    ],
    "src/**/*.{css,scss,styled.js,styled.ts}": [
      "npx stylelint --fix --quiet --cache"
    ]
  },
