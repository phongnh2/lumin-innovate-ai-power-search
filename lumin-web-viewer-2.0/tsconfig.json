{
  "compilerOptions": {
    "sourceMap": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "noImplicitAny": true,
    "noImplicitThis": true,
    "module": "esnext",
    "target": "es6",
    "jsx": "preserve",
    "baseUrl": "./src",
    "allowJs": true,
    "checkJs": false,
    "moduleResolution": "node",
    "lib": ["DOM", "ES6", "DOM.Iterable", "ScriptHost", "ES2016.Array.Include", "ES2021.String", "ES2021.promise", "ES2022.Error"],
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@new-ui/*": ["lumin-components/GeneralLayout/*"],
      "luminComponents/*": ["lumin-components/*"],
      "event-listeners/*": ["event-listeners/*"],
      "graphQL/*": ["graphql/*"],
      "actions": ["redux/actions"],
      "actions/*": ["redux/actions/*"],
      "selectors": ["redux/selectors"],
      "reducers/*": ["redux/reducers/*"],
      "store": ["redux/store"],
      "assets/*": ["./assets/*"],
      "features/*": ["features/*"],
      "@socket": ["./socket"],
      "@libs/*": ["libs/*"],
      "lumin-ui/core": ["../node_modules/lumin-ui/dist/core"],
      "lumin-ui/style.css": ["../node_modules/lumin-ui/dist/core/lumin.css"],
      "lumin-ui/kiwi-ui": ["../node_modules/lumin-ui/dist/kiwi-ui"],
      "lumin-ui/tokens.css": ["../node_modules/lumin-ui/dist/design-tokens/kiwi/css/index.css"],
      "lumin-ui/tokens": ["../node_modules/lumin-ui/dist/design-tokens/kiwi/js"],
      "lumin-ui/tokens/*": ["../node_modules/lumin-ui/dist/design-tokens/kiwi/js/*"],
      "@app-apollo": ["apollo/index.js"],
      "@web-new-ui/*": ["lumin-components/ReskinLayout/*"],
      "lumin-ui/kiwi-style.css": ["../node_modules/lumin-ui/dist/kiwi-ui/kiwi.css"],
      "lumin-ui/kiwi-icon.css": ["../node_modules/lumin-ui/dist/kiwi-ui/font-icomoon/styles/icons.css"],
      "@mf/*": ["../@mf-types/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "index.d.ts",
    "custom.svg.ts",
    "src/**/*.d.ts",
    "electron/**/*.ts",
    "settings/env.d.ts"
  ],
  "exclude": ["node_modules", "dist", "build"]
}