    "<rootDir>/apollo/",
    "<rootDir>/axios/",
    "<rootDir>/core/",
    "<rootDir>/event-listeners/",
    "<rootDir>/socket/"
  ],
  "coverageReporters": ["json-summary","json", "html", "lcov"],
  "moduleNameMapper": {
    "\\.(svg(\\?component)?)$": "<rootDir>/__mocks__/svgMock.js",
    "\\.(jpg|jpeg|png|gif|eot|otf|webp|ttf|woff|woff2|mp4|webm|wav|mp3|m4a|aac|oga)$": "<rootDir>/__mocks__/fileMock.js",
    "\\.(css|scss)$": "identity-obj-proxy",
    "^src(.*)$": "<rootDir>/$1",
    "^luminComponents(.*)$": "<rootDir>/lumin-components/$1",
    "^lumin-components(.*)$": "<rootDir>/lumin-components/$1",
    "^helpers(.*)$": "<rootDir>/helpers/$1",
    "^selectors(.*)$": "<rootDir>/redux/selectors/$1",
    "^constants/(.*)$": "<rootDir>/constants/$1",
    "^hooks(.*)$": "<rootDir>/hooks/$1",
    "^actions(.*)$": "<rootDir>/redux/actions/$1",
    "^reducers(.*)$": "<rootDir>/redux/reducers/$1",
    "^core((/.*)?)$": "<rootDir>/core/$1",
    "^utils(.*)$": "<rootDir>/utils/$1",
    "^assets(.*)$": "<rootDir>/assets/$1",
    "^graphQL(.*)$": "<rootDir>/graphql/$1",
    "^screens(.*)$": "<rootDir>/screens/$1",
    "^services(.*)$": "<rootDir>/services/$1",
    "^HOC(.*)$": "<rootDir>/HOC/$1",
    "^layouts(.*)$": "<rootDir>/layouts/$1",
    "^store(.*)$": "<rootDir>/redux/store/$1",
    "^navigation(.*)$": "<rootDir>/navigation/$1",
    "^ui(.*)$": "<rootDir>/ui/$1",
    "/react-spring/": "<rootDir>/node_modules/react-spring/web.cjs.js",
    "/react-spring/renderprops/": "<rootDir>/node_modules/react-spring/renderprops.cjs.js",
    "^theme-providers(.*)$": "<rootDir>/theme-providers/$1",
    "^interfaces(.*)$": "<rootDir>/interfaces/$1",
    "^features(.*)$": "<rootDir>/features/$1",
    "^event-listeners(.*)$": "<rootDir>/event-listeners/$1",
    "^@socket(.*)$": "<rootDir>/socket/$1",
    "^@new-ui(.*)$": "<rootDir>/lumin-components/GeneralLayout/$1",
    "^@libs(.*)$": "<rootDir>/libs/$1",
    "^@app-apollo(.*)$": "<rootDir>/apollo/$1",
    "^lumin-ui/kiwi-ui": "<rootDir>/../node_modules/lumin-ui/dist/kiwi-ui",
    "lumin-ui/tokens": "<rootDir>/../node_modules/lumin-ui/dist/design-tokens/kiwi/js"
  },
  "testEnvironmentOptions": {
    "resources": "usable"
  },
  "transformIgnorePatterns": ["<rootDir>/node_modules/(?!(react-spring|@material-ui)/)"],
  "testEnvironment": "jsdom",
  "transform": {
    "^.+\\.(js|jsx|ts|tsx)$": ["babel-jest", {
      "presets": [
        ["@babel/preset-env", { "targets": { "node": "current" }}],
        "@babel/preset-react",
        "@babel/preset-typescript"
      ],
      "plugins": [
        "@babel/plugin-proposal-class-properties",
        "@babel/plugin-transform-runtime",
        "@babel/plugin-proposal-optional-chaining",
        "@babel/plugin-proposal-nullish-coalescing-operator",
        "@babel/plugin-transform-private-methods"
      ]
    }]
  }
