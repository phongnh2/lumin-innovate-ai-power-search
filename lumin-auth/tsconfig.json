{
  "compilerOptions": {
    "jsxImportSource": "@emotion/react",
    "target": "es5",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "strictNullChecks": true,
    "strictPropertyInitialization": false,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@kiwi-ui": ["node_modules/lumin-ui/dist/kiwi-ui"],
      "@kiwi-tokens.css": ["node_modules/lumin-ui/dist/design-tokens/kiwi/css/index.css"],
      "@kiwi-tokens": ["node_modules/lumin-ui/dist/design-tokens/kiwi/js"],
      "@kiwi-style.css": ["node_modules/lumin-ui/dist/kiwi-ui/kiwi.css"],
      "@kiwi-icon.css": ["node_modules/lumin-ui/dist/kiwi-ui/font-icomoon/styles/icons.css"],
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "index.d.ts",
    "global.d.ts",
    "jest.setup.ts"
  ],
  "exclude": [
    "node_modules"
  ],
  "plugins": [
    {
      "name": "typescript-styled-plugin",
      "tags": [
        "styled",
        "css",
        "mediaQuery"
      ]
    }
  ],
  "types": ["@testing-library/jest-dom"]
}
