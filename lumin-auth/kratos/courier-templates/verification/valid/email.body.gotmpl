              <tr style="margin: 0;">
                <td align="left" style="margin: 0; font-size: 0px; padding: 0; word-break: break-word;">
                  
      <div style="margin: 0; font-family: Roboto, sans-serif; font-size: 15px; line-height: 22px; text-align: left; color: #102d42;"><h3 style="margin: 0; font-weight: 500; font-size: 22px; line-height: 28px;">Your email address has been confirmed</h3></div>
    
