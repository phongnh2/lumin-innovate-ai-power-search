<mjml>
<mj-head>
  <mj-title>{{ title }}</mj-title>

  <mj-attributes>
    <mj-body background-color="#fdf7f6" />
    <mj-section padding="0" />
    <mj-social padding="0" />
    <mj-social-element padding="0 8px" background-color="transparent"/>
    <mj-image padding="0" />

    <mj-text
      font-family="Roboto, sans-serif"
      font-size="15px"
      line-height="22px"
      color="#102d42"
      padding="0"
    />

    <mj-button
      font-family="Roboto, sans-serif"
      background-color="#f2385a"
      border-radius="8px"
      font-size="17px"
      font-weight="500"
      line-height="24px"
      padding="0"
      inner-padding="12px 16px"
    />

    <mj-divider
      border-color="#dae4ec"
      border-width="1px"
      padding="0"
    />

    <!-- text color -->
    <mj-class name="text-neutral-70" color="#48687f" />
    <mj-class name="text-neutral-100" color="#102d42" />
    <mj-class name="text-secondary-50" color="#f2385a" />

    <!-- font size -->
    <mj-class name="text-sm" font-size="12px" line-height="16px" />
    <mj-class name="text-base" font-size="15px" line-height="22px" />

    <!-- font weight -->
    <mj-class name="font-medium" font-weight="500"/>

    <mj-class name="underline" text-decoration="underline" />
  </mj-attributes>

  <mj-style inline="inline">
    * {
      margin: 0;
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    h3 {
      font-weight: 500;
      font-size: 22px;
      line-height: 28px;
    }

    .text-secondary-50 { color: #f2385a; }
    .font-medium { font-weight: 500; }
    .mj-column-px-56 {
    	width: 56px !important;
    }
    .link-secondary {
      color: #101828;
      text-decoration: underline;
    }
    .text-bold {
      font-weight: 600;
      letter-spacing: 0.1px;
    }
  </mj-style>
  <mj-style>
    @media only screen and (min-width: 480px) {
      .download > table > tbody > tr > td {
        padding: 24px !important;
        text-align: left !important;
        display: flex;
        height: 44px;
      }
      .download-text-wrapper {
        padding-right: 24px;
        width: 185px!important;
        }
      .download-text-wrapper > table > tbody > tr > td {
        padding-right: 24px;
        width: 185px!important;
        }
      .download-text {
        padding-bottom: 0px!important;
      }
      .social > table > tbody > tr > td {
        display: flex;
        padding: 8px 0px !important;
      }
      .address-text-wrapper > table > tbody > tr > td {
          padding-top: 6px !important;
        }
      .address-text {
        padding: 0px!important;
      }
      .social-logo {
        width: 192px!important;
      }
      .download-logo {
        padding-top: 2px !important;
      }
      .logo-item {
        padding-right: 24px !important;
        width: 24px !important;
      }
    	.lumin-section-app > table > tbody > tr > td {
        padding: 16px 24px !important;
    		text-align: left !important;
        display: flex;
      }
    }
    @media only screen and (max-width: 480px) {
      .mj-main-pager {
        max-width: calc(100% - 16px) !important;
      }
      .social-logo {
        width: 224px!important;
        padding: 8px 0px !important;
        align-items: flex-start !important;
        display: flex !important;
      }
      .download-logo {
        width: 272px!important;
        align-items: flex-start !important;
        display: flex !important;
      }
      .download-ios > table > tbody > tr > td {
        padding-right: 16px !important;
      }
      .download-ios {
    		width: 136px !important;
			}
    	.download-android {
    		width: 136px !important;
    	}
      .footer-wrapper {
        padding: 0px 8px !important;
      }
      .logo-item {
        padding-right: 16px !important;
        width: 24px !important;
      }
    	.lumin-section-app > table > tbody > tr > td {
        padding: 24px !important;
      }
    	.intro-account {
    		padding-bottom: 10px;
			}
    	.lumin-logo {
        align-items: flex-start !important;
        display: flex !important;
      }
    	.lumin-logo-item {
    		width: 44px !important;
			}
    }
  </mj-style>
</mj-head>

<mj-body>
  <mj-section>
    <mj-column>
      <mj-spacer height="64px" />
    </mj-column>
  </mj-section>

  <mj-wrapper
    background-color="#fab1a5"
    border-radius="8px"
    padding="1px"
  >
    <mj-section>
      <mj-column padding="24px" border-radius="8px 8px 0 0" background-color="#fff">
        <mj-image
          height="32px"
          width="118px"
          align="left"
          src="{{ assetsUrl }}/images/lumin-new-logo.png"
          alt="logo"
        />
      </mj-column>
    </mj-section>

    <!-- divider -->
    <mj-section>
      <mj-column>
        <mj-divider />
      </mj-column>
    </mj-section>

    <mj-section>
      <mj-column padding="32px 24px 24px" background-color="#fff">

        {{> @partial-block }}

        <mj-spacer height="32px" />
        <mj-divider align="left" width="40px"/>

        <mj-spacer height="24px" />
        <mj-text mj-class="text-neutral-70">Cheers,</mj-text>

        <mj-spacer height="8px" />
        <mj-text mj-class="font-medium">The Lumin Team</mj-text>
      </mj-column>
    </mj-section>

    <!-- divider -->
    <mj-section>
      <mj-column>
        <mj-divider />
      </mj-column>
    </mj-section>
    
    <mj-section border-radius="0 0 8px 8px" background-color="#fff" css-class="lumin-section-app" padding="0" css-class="logo-wrapper">
      <mj-column padding="6px 24px 6px 0" width="264px" css-class="intro-account">
        <mj-text align="left">
          One account for all Lumin products
        </mj-text>
      </mj-column>
      <mj-group width="88px" css-class="lumin-logo">
        <mj-column padding="0 12px 0 0" width="44px" css-class="lumin-logo-item">
          <mj-image height="32px" width="32px" src="{{ assetsUrl }}/images/lumin-rounded.png" alt="lumin-logo" align="left"/>
        </mj-column>
        <mj-column padding-left="12px" width="44px" css-class="lumin-logo-item">
          <mj-image height="32px" width="32px" src="{{ assetsUrl }}/images/lumin-sign-rounded.png" alt="lumin-sign-logo" align="left"/>
        </mj-column>
      </mj-group>
    </mj-section>
     
  </mj-wrapper>

  <!-- footer -->
  <mj-wrapper css-class="footer-wrapper">

    <mj-section padding="0">
        <mj-column>
          <mj-spacer height="24px" />
        </mj-column>
    </mj-section>

    <mj-section padding="24px 16px" css-class="download" background-color='white' border-radius='8px'>
      <mj-column width="332px" css-class="download-text-wrapper">
        <mj-text align="left" padding="0px" css-class="download-text" padding-bottom="14px" color="#101828">
          Get notified of comments and updates on the go.
        </mj-text>
      </mj-column>
      <mj-group width="280px" css-class="download-logo">
        <mj-column padding-right="24px" width="144px" css-class="download-ios">
          <mj-image width="120px" padding="0" src="{{ assetsUrl }}/images/app-store.png"
          href="https://lumin-mobile.app.link/email-download-link-ios"/>
        </mj-column>
        <mj-column width="136px" css-class="download-android">
          <mj-image width="136px" padding="0" src="{{ assetsUrl }}/images/google-play.png"
          href="https://lumin-mobile.app.link/email-download-link-android"/>
        </mj-column>
      </mj-group>
    </mj-section>
  
    <mj-section padding="0">
      <mj-column>
        <mj-spacer height="40px" />
      </mj-column>
    </mj-section>

    <mj-section padding="0px" css-class="social">
      <mj-column padding="0px" width="432px" css-class="address-text-wrapper">
        <mj-text align="left" font-size="12px" padding="0px" css-class="address-text" padding-bottom="16px" color="#667085">
          Lumin 101/210 Armagh Street, Christchurch, New Zealand
        </mj-text>
      </mj-column>
      <mj-group width="224px" css-class="social-logo">
        <mj-column css-class="logo-item">
          <mj-image height="24px" width="24px" padding="0" src="{{ assetsUrl }}/images/facebook-logo.png"
          href="https://www.facebook.com/luminpdf/"/>
        </mj-column>
        <mj-column  css-class="logo-item">
          <mj-image height="24px" width="24px" padding="0" src="{{ assetsUrl }}/images/linkedin-logo.png"
          href="https://www.linkedin.com/company/lumin-pdf/"/>
        </mj-column>
        <mj-column  css-class="logo-item">
          <mj-image height="24px" width="24px" padding="0" src="{{ assetsUrl }}/images/instagram-logo.png"
          href="https://instagram.com/lumin.pdf?igshid=j3rda8ed0wba"/>
        </mj-column>
        <mj-column css-class="logo-item">
          <mj-image height="24px" width="24px" padding="0" src="{{ assetsUrl }}/images/youtube-logo.png"
          href="https://www.youtube.com/channel/UCbTsMqXJ5AGqapXaBhzPw8g"/>
        </mj-column>
      </mj-group>
    </mj-section>

    <mj-section padding="0">
      <mj-column>
        <mj-spacer height="24px" />
      </mj-column>
    </mj-section>

    <mj-section padding-bottom="32px">
      <mj-column width="100%" padding="0">
        <mj-text font-size="12px" color="#667085" padding="0px" align="left" line-height="16px">
          You received this email because you recently created an account on Lumin.
          To stop receiving these emails, you can <a class="link-secondary text-bold" href="{{baseUrl}}/setting/preferences">
            change your email preferences
          </a>
        </mj-text>
      </mj-column>
    </mj-section>

  </mj-wrapper>
</mj-body>
</mjml>
