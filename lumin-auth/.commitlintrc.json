{
  "extends": ["@commitlint/config-conventional"],
  "rules": {
    "type-enum": [
      2,
      "always",
      ["✨ feat", "🐛 fix", "♻️ refactor", "⚡️ chore", "⏪ revert", "🚑️ hotfix", "🚧 wip", "🚀 BREAKING CHANGE"]
    ],
    "type-empty": [0, "never"],
    "type-case": [0, "never"],
    "subject-empty": [0, "never"],
    "scope-case": [0, "never"],
    "header-max-length": [2, "always", 160]
  }
}
