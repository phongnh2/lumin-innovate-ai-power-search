# Lumin WebOpt MF - Environment Variables
# Copy this file to .env and fill in the values

# Environment
LUMIN_ENVIRONMENT_NAME=local
LUMIN_VERSION=1.0.0

# Base URLs
LUMIN_BASE_URL=http://localhost:3600
LUMIN_PDF_APP_URL=http://localhost:3000
LUMIN_PDF_BACKEND_URL=http://localhost:4200
LUMIN_PDF_SERVER_URL=http://localhost:8765

# Authentication
LUMIN_KRATOS_URL=http://localhost:4433
LUMIN_AUTH_SERVICE_URL=http://localhost:3300

# Static Pages
LUMIN_STATIC_PAGE_URL=http://localhost:3005

# AI + Templates API (lumin-wo-ai-innovate)
LUMIN_INNOVATE_URL=http://localhost:8765

# JWT Config
LUMIN_AUTHOR_JWT_EXPIRED_AT=1680000

# Module Federation
LUMIN_WEBOPT_PREFIX=lumin-webopt-mf

# Monitoring (optional, leave empty for local)
LUMIN_DATADOG_CLIENT_TOKEN=

# Claude AI API Key (for AI-powered suggestions in Smart Finding)
LUMIN_CLAUDE_API_KEY=

# Set to "true" to bypass all Claude / prompt-generation API calls and return
# randomized mock data instead. Useful for local dev without burning AI budget.
LUMIN_DISABLE_CLAUDE=false

# Optional: override the default context sent to /api/v2/prompts
# LUMIN_PROMPT_CONTEXT=

