  "name": "lumin-web-viewer-backend2",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "prepare-commit-msg": "node scripts/prepare-commit-msg.js",
    "start": "node dist/main.js",
    "build": "webpack --progress --mode=production",
    "dev": "NODE_ENV=development npm run clean && npm run build:dependencies && concurrently --raw --kill-others \"npm run watch:graphql\" \"npm run start:dev\"",
    "clean": "rimraf dist .cache",
    "start:dev": "webpack --mode=development --watch --progress --color",
    "build:dependencies": "npm run gen-roles && npm run gen-roles:document && npm run build:mjml",
    "build:graphql": "ts-node src/generate-typings.ts",
    "build:mjml": "npx gulp build",
    "watch:graphql": "ts-node src/generate-typings.ts --watch",
    "watch:mjml": "npx gulp watch",
    "eslint-build": "git diff --name-only origin/$npm_config_branch | grep -E '\\.(js|ts)$' | xargs -r sh -c 'oxlint --quiet \"$@\" && eslint --quiet --no-error-on-unmatched-pattern \"$@\"' _",
    "test": "nyc npm run test:policy && jest -w 1 --silent",
    "test:coverage": "nyc npm run test -- --coverage",
    "test:badges": "nyc npm run test:coverage && jest-coverage-badges input \"coverage/coverage-summary.json\" output \"badges\"",
    "test:policy": "ts-node src/Organization/test/policy-testing.ts",
    "test:policy:document": "ts-node src/Document/ActionPermission/test/policy-testing.ts",
    "test:coverage:report": "node scripts/report-test-coverage.js",
    "gen-schema": "apollo client:download-schema introspection.json",
    "gen-roles": "ts-node src/Organization/Policy/generator/role.generator.ts",
    "gen-roles:document": "ts-node src/Document/ActionPermission/Policy/generator/role.generator.ts",
    "gen-policy": "ts-node src/Organization/Policy/generator/policy.generator.ts",
    "gen-policy:document": "ts-node src/Document/ActionPermission/Policy/generator/policy.generator.ts",
    "gen-policy-uuid": "uuid v5 $npm_config_operation 33fab379-6bf6-4ce5-a9f6-e73e9c8d7e89",
    "prepare": "npx husky install"
  },
  "lint-staged": {
    "*.ts": [
      "npx oxlint --fix-suggestions",
      "npx eslint --fix --quiet"
    ]
  },
