{
  "extends": ["@commitlint/config-conventional"],
  "rules": {
    "type-enum": [
      2,
      "always",
      [
        "✨ feat", "🐛 fix", "♻️ refactor", "⚡️ chore", "⏪ revert", "🚑️ hotfix", "🚧 wip", "🚀 BREAKING CHANGE",
        "📝 docs", "✅ test", "🔧 config", "🔒 security", "⚡ perf", "⭐ enhance"
      ]
    ],
    "type-empty": [0, "never"],
    "type-case": [0, "never"],
    "subject-empty": [0, "never"],
    "scope-case": [0, "never"],
    "header-max-length": [0, "always", 160]
  }
}
